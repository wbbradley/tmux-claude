#!/bin/sh
set -e

BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
STATE_DIR="/tmp/tmux-claude-$(id -u)"
SETTINGS="$HOME/.claude/settings.local.json"
LEGACY_SETTINGS="$HOME/.claude/settings.json"
# 1. Create state directory
mkdir -p "$STATE_DIR"

# 2. Remove any legacy tmux-claude hooks from settings.json (previous install location)
if [ -f "$LEGACY_SETTINGS" ]; then
    python3 -c '
import json, sys

settings_path = sys.argv[1]

with open(settings_path) as f:
    settings = json.load(f)

hooks = settings.get("hooks", {})
changed = False

for event in list(hooks.keys()):
    cleaned = [e for e in hooks[event] if not any(
        "tmux-claude-" in h.get("command", "")
        for h in e.get("hooks", [])
    )]
    if len(cleaned) != len(hooks[event]):
        changed = True
    if cleaned:
        hooks[event] = cleaned
    else:
        del hooks[event]

if changed:
    if hooks:
        settings["hooks"] = hooks
    elif "hooks" in settings:
        del settings["hooks"]
    with open(settings_path, "w") as f:
        json.dump(settings, f, indent=2)
        f.write("\n")
    print("Removed legacy tmux-claude hooks from " + settings_path)
' "$LEGACY_SETTINGS"
fi

# 3. Merge hooks into settings.local.json
if [ ! -f "$SETTINGS" ]; then
    echo '{}' > "$SETTINGS"
fi

python3 -c '
import json, sys

bin_dir = sys.argv[1]
settings_path = sys.argv[2]

with open(settings_path) as f:
    settings = json.load(f)

hooks = settings.get("hooks", {})

# Define the hooks we want to add
tmux_hooks = {
    "Stop": [
        {
            "matcher": "",
            "hooks": [{"type": "command", "command": bin_dir + "/tmux-claude-notify"}]
        }
    ],
    "Notification": [
        {
            "matcher": "",
            "hooks": [{"type": "command", "command": bin_dir + "/tmux-claude-notify"}]
        }
    ],
    "PreToolUse": [
        {
            "matcher": "AskUserQuestion",
            "hooks": [{"type": "command", "command": bin_dir + "/tmux-claude-notify"}]
        }
    ],
    "PermissionRequest": [
        {
            "matcher": "",
            "hooks": [{"type": "command", "command": bin_dir + "/tmux-claude-notify"}]
        }
    ],
    "UserPromptSubmit": [
        {
            "matcher": "",
            "hooks": [{"type": "command", "command": bin_dir + "/tmux-claude-resume"}]
        }
    ],
    "SessionEnd": [
        {
            "matcher": "",
            "hooks": [{"type": "command", "command": bin_dir + "/tmux-claude-cleanup"}]
        }
    ],
}

for event, new_entries in tmux_hooks.items():
    existing = hooks.get(event, [])
    # Remove any previous tmux-claude entries
    cleaned = [e for e in existing if not any(
        "tmux-claude-" in h.get("command", "")
        for h in e.get("hooks", [])
    )]
    cleaned.extend(new_entries)
    hooks[event] = cleaned

settings["hooks"] = hooks

with open(settings_path, "w") as f:
    json.dump(settings, f, indent=2)
    f.write("\n")
' "$BIN_DIR" "$SETTINGS"

echo "Hooks merged into $SETTINGS"

# 4. Configure tmux (now if inside tmux, otherwise lazily on first hook fire)
"$BIN_DIR/tmux-claude-ensure-tmux"
if [ -n "$TMUX" ]; then
    echo "tmux configured: status bar + prefix-g binding + focus-clears-waiting"
else
    echo "Not inside tmux — tmux will be configured automatically on first Claude hook fire"
fi

echo ""
echo "tmux-claude setup complete."
echo "  Status bar: shows [Claude waiting] when sessions need input"
echo "  prefix + g: jump to the oldest waiting Claude pane"
echo "  Run '$BIN_DIR/tmux-claude-teardown' to uninstall"
